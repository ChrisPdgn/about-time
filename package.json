{
  "name": "about-time",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered scheduling buddy - a personal scheduling assistant with voice commands",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:backend": "pnpm --filter @about-time/backend run dev",
    "dev:frontend": "pnpm --filter @about-time/frontend run dev",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter @about-time/backend run build",
    "build:frontend": "pnpm --filter @about-time/frontend run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0"
}
